---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('posts');
  const publishedPosts = allPosts.filter(post => !post.data.draft).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(publishedPosts, { pageSize: 9 });
}

// All paginated data is passed on the "page" prop
const { page } = Astro.props;
---

<Layout title={`Blog Archives - Page ${page.currentPage}`} description="Browse the latest crypto mining intelligence and ASICs reviews.">
    <div class="max-w-7xl mx-auto px-6 py-20">
        <header class="text-center mb-16">
            <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6">Mining <span class="text-crypto-primary">Intelligence</span></h1>
            <p class="text-crypto-muted text-lg max-w-2xl mx-auto">Archived performance logs, pool metrics, and hardware benchmarks.</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {page.data.map((post) => (
                <a href={`/blog/${post.id}/`} class="glass-card overflow-hidden group flex flex-col border border-crypto-border transition-all hover:border-crypto-primary/50 hover:shadow-[0_0_20px_rgba(0,255,65,0.1)] hover:-translate-y-1">
                    <div class="w-full h-48 overflow-hidden border-b border-crypto-border relative">
                        <div class="absolute top-4 left-4 z-10 flex gap-2">
                            <span class="bg-black/80 backdrop-blur border border-crypto-primary text-crypto-primary px-3 py-1 rounded text-[10px] font-black uppercase tracking-widest">{post.data.category}</span>
                        </div>
                        {post.data.heroImage ? (
                            <Image src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        ) : (
                            <div class="w-full h-full bg-crypto-bg border-b border-crypto-border/50"></div>
                        )}
                    </div>
                    <div class="p-6 flex-grow flex flex-col pt-6">
                        <h4 class="text-xl font-bold text-white mb-3 group-hover:text-crypto-primary transition-colors leading-snug">{post.data.title}</h4>
                        <p class="text-crypto-muted text-sm line-clamp-3 mb-6 flex-grow">{post.data.description}</p>
                        <div class="flex items-center justify-between text-xs font-mono text-crypto-text mt-auto pt-4 border-t border-crypto-border/50">
                            <span>{post.data.pubDate.toLocaleDateString('en-us', { month: 'short', day: 'numeric', year: 'numeric'})}</span>
                            <span class="text-crypto-primary">{post.data.readTime}</span>
                        </div>
                    </div>
                </a>
            ))}
        </div>

        <!-- Pagination Navigation -->
        {page.lastPage > 1 && (
            <div class="mt-16 flex justify-center gap-4">
                {page.url.prev ? (
                    <a href={page.url.prev} class="px-6 py-3 border border-crypto-border bg-crypto-card text-white hover:border-crypto-primary hover:text-crypto-primary rounded-xl font-bold transition-colors">Previous</a>
                ) : (
                    <span class="px-6 py-3 border border-crypto-border/30 bg-crypto-bg text-crypto-muted rounded-xl font-bold cursor-not-allowed">Previous</span>
                )}
                
                <span class="px-6 py-3 bg-crypto-primary/10 text-crypto-primary border border-crypto-primary rounded-xl font-bold">
                    Page {page.currentPage} of {page.lastPage}
                </span>

                {page.url.next ? (
                    <a href={page.url.next} class="px-6 py-3 border border-crypto-border bg-crypto-card text-white hover:border-crypto-primary hover:text-crypto-primary rounded-xl font-bold transition-colors">Next</a>
                ) : (
                    <span class="px-6 py-3 border border-crypto-border/30 bg-crypto-bg text-crypto-muted rounded-xl font-bold cursor-not-allowed">Next</span>
                )}
            </div>
        )}
    </div>
</Layout>
