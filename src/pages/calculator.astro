---
import Layout from '../layouts/Layout.astro';
import MiningCalculator from '../components/MiningCalculator.jsx';
---

<Layout title="Mining Calculator" description="Calculate your Bitcoin mining profitability instantly.">
    		<div class="max-w-4xl mx-auto rounded-3xl overflow-hidden shadow-2xl relative min-h-[600px] border border-crypto-border">
			<div class="absolute inset-0 bg-gradient-to-br from-crypto-card to-crypto-bg z-0 pointer-events-none"></div>
			<MiningCalculator client:visible />
		</div>
</Layout>
