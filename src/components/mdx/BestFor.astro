---
export interface Props {
    title?: string;
    audiences: string[];
}
const { title = "Best For:", audiences = [] } = Astro.props;
---
<div class="my-6 p-6 rounded-xl bg-gradient-to-br from-crypto-primary/10 to-transparent border border-crypto-primary/30 not-prose">
    <h4 class="text-white font-extrabold flex items-center gap-2 mb-4 mt-0 uppercase tracking-widest text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-crypto-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" /></svg>
        {title}
    </h4>
    <div class="flex flex-wrap gap-2 m-0 p-0">
        {audiences.map(a => <span class="bg-crypto-card border border-crypto-primary/50 text-crypto-primary px-3 py-1 rounded-full text-xs font-bold">{a}</span>)}
    </div>
</div>
