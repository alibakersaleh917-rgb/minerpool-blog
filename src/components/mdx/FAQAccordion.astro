---
export interface Props {
    title: string;
}
const { title } = Astro.props;
---
<details class="group border border-crypto-border bg-crypto-card rounded-xl my-4 overflow-hidden">
    <summary class="flex justify-between items-center cursor-pointer p-6 font-bold text-lg text-white hover:text-crypto-primary transition-colors">
        {title}
        <span class="transition duration-300 group-open:-rotate-180 text-crypto-primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
        </span>
    </summary>
    <div class="p-6 pt-0 text-crypto-text text-base leading-relaxed border-t border-crypto-border/50 bg-crypto-bg/50">
        <slot />
    </div>
</details>
