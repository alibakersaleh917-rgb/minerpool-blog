---
export interface Props {
    pros: string[];
    cons: string[];
}
const { pros = [], cons = [] } = Astro.props;
---
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-8">
    <div class="border border-crypto-border bg-crypto-card rounded-xl p-6">
        <h4 class="text-crypto-primary uppercase tracking-widest text-sm font-bold border-b border-crypto-border pb-3 mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Pros
        </h4>
        <ul class="space-y-3 m-0 p-0 list-none">
            {pros.map(p => <li class="text-white text-sm flex items-start gap-2"><span class="text-crypto-primary font-bold mt-0.5">•</span><span set:html={p}></span></li>)}
        </ul>
    </div>
    <div class="border border-crypto-border bg-crypto-card rounded-xl p-6">
        <h4 class="text-red-400 uppercase tracking-widest text-sm font-bold border-b border-crypto-border pb-3 mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            Cons
        </h4>
        <ul class="space-y-3 m-0 p-0 list-none">
            {cons.map(c => <li class="text-white text-sm flex items-start gap-2"><span class="text-red-400 font-bold mt-0.5">•</span><span set:html={c}></span></li>)}
        </ul>
    </div>
</div>
