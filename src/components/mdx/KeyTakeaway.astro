---
export interface Props {
    title?: string;
}
const { title = "Key Takeaway" } = Astro.props;
---
<div class="border border-crypto-primary/30 bg-crypto-primary/5 p-6 rounded-xl my-8 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-1 h-full bg-crypto-primary"></div>
    <h4 class="text-crypto-primary font-extrabold flex items-center gap-2 mb-3 mt-0 uppercase tracking-widest text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        {title}
    </h4>
    <div class="text-white font-semibold text-lg leading-relaxed"><slot /></div>
</div>
