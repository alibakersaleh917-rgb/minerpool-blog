---
export interface Props {
    title: string;
    description: string;
    buttonText: string;
    buttonLink: string;
}
const { title, description, buttonText, buttonLink } = Astro.props;
---
<div class="bg-gradient-to-r from-crypto-card to-crypto-bg border border-crypto-primary/50 relative overflow-hidden rounded-2xl p-8 my-10 shadow-[0_0_25px_rgba(0,255,65,0.1)] flex flex-col md:flex-row items-center justify-between gap-8 not-prose">
    <div class="absolute -right-[10%] -top-[50%] w-64 h-64 bg-crypto-primary/20 blur-[80px] rounded-full z-0 pointer-events-none"></div>
    <div class="relative z-10 max-w-xl">
        <h3 class="text-2xl font-extrabold text-white mb-2 mt-0">{title}</h3>
        <p class="text-crypto-muted text-sm mt-0 mb-0">{description}</p>
    </div>
    <div class="relative z-10 w-full md:w-auto flex-shrink-0">
        <a href={buttonLink} target="_blank" rel="noopener noreferrer nofollow" class="inline-block w-full md:w-auto bg-crypto-primary hover:bg-green-500 text-black px-8 py-4 rounded-xl font-extrabold text-center transition-transform hover:-translate-y-1 shadow-[0_4px_20px_rgba(0,255,65,0.4)] truncate">
            {buttonText}
        </a>
        <p class="text-[10px] text-crypto-muted text-center mt-3 uppercase tracking-widest leading-none m-0 p-0">Sponsored / Affiliate</p>
    </div>
</div>
